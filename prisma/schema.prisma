generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  name         String?
  ageClass     String?
  city         String?
  address      String?
  profileImage String?
  contact      String       @unique
  authMode     String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  results      QuizResult[]
}

model QuizResult {
  id               String   @id @default(cuid())
  userId           String
  setIndex         Int
  totalScore       Int
  totalCorrect     Int
  totalQuestions   Int
  categoryScores   String
  personalityType  String
  personalityEmoji String
  personalityDesc  String
  topStrengths     String   @default("[]")
  areasToImprove   String   @default("[]")
  skillPlan        String   @default("[]")
  careers          String
  hiddenTalent     String
  hiddenTalentDesc String
  answers          String
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
}
