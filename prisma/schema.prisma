generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String       @id @default(cuid())
  name             String?
  age              String?
  studentClass     String?
  ageClass         String?      // Keeping for backward compatibility if needed, but we'll use age and studentClass
  city             String?
  address          String?
  profileImage     String?
  contact          String       @unique
  email            String?      @unique
  authMode         String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  results          QuizResult[]
  enrollments      Enrollment[]
  courseEnrollments CourseEnrollment[]
  notifications    Notification[]
  
  // Dynamic profile theme fields
  personalityType  String?
  personalityEmoji String?
  themeColor       String?
  personalityDesc  String?
  primaryTrait     String?
  
  // Auth fields
  password         String?
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  createdAt DateTime @default(now())
  expiresAt DateTime
}


model Competition {
  id          String   @id @default(cuid())
  title       String
  description String
  formLink    String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  enrollments Enrollment[]
}

model Enrollment {
  id            String      @id @default(cuid())
  userId        String
  competitionId String
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id])
  competition   Competition @relation(fields: [competitionId], references: [id])

  @@unique([userId, competitionId])
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  thumbnail   String?
  published   Boolean  @default(false)
  price       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lessons     Lesson[]
  enrollments CourseEnrollment[]
}

model Lesson {
  id              String   @id @default(uuid())
  courseId        String
  title           String
  description     String?
  content         String?
  youtubeVideoId  String?
  order           Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseEnrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  enrolledAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  @@unique([userId, courseId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model QuizResult {
  id               String   @id @default(cuid())
  userId           String
  setIndex         Int
  totalScore       Int
  totalCorrect     Int
  totalQuestions   Int
  categoryScores   String
  personalityType  String
  personalityEmoji String
  personalityDesc  String
  topStrengths     String   @default("[]")
  areasToImprove   String   @default("[]")
  skillPlan        String   @default("[]")
  careers          String
  hiddenTalent     String
  hiddenTalentDesc String
  learningStyle    String   @default("")
  workEnvironment  String   @default("")
  actionableAdvice String   @default("")
  answers          String
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
}

model Mentor {
  id          String   @id @default(uuid())
  name        String
  photo       String?
  description String
  iitBranch   String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CouponAttempt {
  id          String   @id @default(uuid())
  phone       String   @unique
  couponCode  String   @unique
  score       Int
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())
}
